#!/bin/sh
# Git pre-commit hook - 桀洛 & 嘉娜的知识库
# 每次 commit 前自动运行部署检查，失败则阻止提交

export PYTHONIOENCODING="utf-8"

CHECK_SCRIPT="$(dirname "$0")/../scripts/deploy-check.py"
if [ ! -f "$CHECK_SCRIPT" ]; then
    echo "[pre-commit] deploy-check.py not found, skipping."
    exit 0
fi

echo "[pre-commit] Running deploy-check.py ..."

python "$CHECK_SCRIPT"
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "[FAIL] Pre-commit check failed! Commit blocked."
    echo "To skip: git commit --no-verify"
    exit 1
fi

echo "[PASS] All checks passed, commit continues."
exit 0
