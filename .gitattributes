# Auto detect text files and perform LF normalization
* text=auto

# Our project files — enforce UTF-8 encoding in repository
# "working-tree-encoding=UTF-8" tells Git: this file MUST be valid UTF-8 at add time
# Git will refuse to add corrupted/chinese-gbk files
*.html        text working-tree-encoding=UTF-8
*.js          text working-tree-encoding=UTF-8
*.css         text working-tree-encoding=UTF-8
*.md          text working-tree-encoding=UTF-8
*.json        text working-tree-encoding=UTF-8
*.py          text working-tree-encoding=UTF-8

# Scripts
*.ps1         text eol=crlf
*.sh          text eol=lf

# Binary files — don't touch
*.png         binary
*.jpg         binary
*.gif         binary
*.ico         binary
*.zip         binary
*.tar.gz      binary
